/* --- Practice: Mini Review Challenge ---
   Mixes Picture Match / Who's This? / Listen & Click / Reading (meaning
   match) into five random questions and scores the result. */
const REVIEW_TYPES = ['picture','whois','listen','reading'];
let rvWordOrder=[], rvTypeOrder=[], rvRound=0, rvScore=0, rvTarget=null, rvType=null, rvLocked=false;

function initMiniReview(){
  rvWordOrder = shuffleArray(WORDS);                      // each of the 5 words appears once
  rvTypeOrder = shuffleArray([...REVIEW_TYPES, REVIEW_TYPES[Math.floor(Math.random()*REVIEW_TYPES.length)]]).slice(0,5);
  rvRound = 0; rvScore = 0;
  document.getElementById('rvScore').textContent = '0';
  document.getElementById('rvResultCard').hidden = true;
  document.getElementById('rvQuestionArea').style.display = '';
  loadRvRound();
}
function loadRvRound(){
  rvLocked = false;
  rvTarget = rvWordOrder[rvRound];
  rvType = rvTypeOrder[rvRound];
  document.getElementById('rvRound').textContent = rvRound+1;
  document.getElementById('rvFeedback').textContent = '';
  document.getElementById('rvFeedback').className = 'feedback-msg';

  const area = document.getElementById('rvQuestionArea');
  area.innerHTML = '';

  if (rvType === 'picture'){
    area.innerHTML = `
      <div class="game-prompt">
        <div class="word-bangla" style="font-size:2.8rem;" lang="bn">${rvTarget.bn}</div>
        <button class="speaker-btn" id="rvSpeaker" aria-label="Play the word">🔊</button>
      </div>
      <div class="choice-grid" id="rvOptions"></div>`;
    document.getElementById('rvSpeaker').addEventListener('click', ()=> AudioEngine.speak(rvTarget.bn));
    const options = shuffleArray([rvTarget, ...buildDistractors(rvTarget)]);
    options.forEach(opt=> addRvChoice(opt, 'choice-card emoji', opt.emoji));
    setTimeout(()=> AudioEngine.speak(rvTarget.bn), 300);

  } else if (rvType === 'whois'){
    area.innerHTML = `
      <div class="game-prompt">
        <div class="word-illustration" style="font-size:5rem; margin-bottom:0;">${rvTarget.emoji}</div>
        <div class="word-bangla" style="font-size:1.8rem;" lang="bn">এটি কে?</div>
      </div>
      <div class="choice-grid" id="rvOptions"></div>`;
    const options = shuffleArray([rvTarget, ...buildDistractors(rvTarget)]);
    options.forEach(opt=> addRvChoice(opt, 'choice-card word', opt.bn, true));

  } else if (rvType === 'listen'){
    area.innerHTML = `
      <div class="game-prompt">
        <button class="speaker-btn" id="rvSpeaker" aria-label="Play the word">🔊</button>
      </div>
      <div class="choice-grid five" id="rvOptions"></div>`;
    document.getElementById('rvSpeaker').addEventListener('click', ()=> AudioEngine.speak(rvTarget.bn));
    const options = shuffleArray(WORDS);
    options.forEach(opt=> addRvChoice(opt, 'choice-card word', opt.bn, true));
    setTimeout(()=> AudioEngine.speak(rvTarget.bn), 300);

  } else { // 'reading' — match the Bangla word to its English meaning
    area.innerHTML = `
      <div class="game-prompt">
        <div class="word-bangla" style="font-size:3rem;" lang="bn">${rvTarget.bn}</div>
      </div>
      <div class="choice-grid" id="rvOptions"></div>`;
    const options = shuffleArray([rvTarget, ...buildDistractors(rvTarget)]);
    options.forEach(opt=> addRvChoice(opt, 'choice-card meaning', opt.en));
  }
}
function addRvChoice(opt, className, label, isBangla){
  const card = document.createElement('button');
  card.className = className;
  if (isBangla) card.setAttribute('lang','bn');
  card.textContent = label;
  card.addEventListener('click', ()=> handleRvAnswer(card, opt));
  document.getElementById('rvOptions').appendChild(card);
}
function handleRvAnswer(card, opt){
  if (rvLocked) return;
  rvLocked = true;
  const fb = document.getElementById('rvFeedback');
  const correct = opt.id === rvTarget.id;
  if (correct){
    rvScore++;
    document.getElementById('rvScore').textContent = rvScore;
    card.classList.add('flash-good');
    fb.textContent = '🎉 Correct!'; fb.className = 'feedback-msg good';
    AudioEngine.beep('correct'); Confetti.burst(50);
  } else {
    card.classList.add('flash-bad');
    fb.textContent = '💛 Not quite!'; fb.className = 'feedback-msg retry';
    AudioEngine.beep('wrong');
    // Reveal the correct option so the child still learns the right answer.
    document.querySelectorAll('#rvOptions .choice-card, #rvOptions button').forEach(c=>{
      if (c.textContent === rvTarget.bn || c.textContent === rvTarget.en || c.textContent === rvTarget.emoji){ c.classList.add('flash-good'); }
    });
  }
  setTimeout(()=>{
    rvRound++;
    if (rvRound < 5){ loadRvRound(); } else { finishMiniReview(); }
  }, 1300);
}
function finishMiniReview(){
  document.getElementById('rvQuestionArea').style.display = 'none';
  document.getElementById('rvFeedback').textContent = '';
  document.getElementById('rvFinalScore').textContent = `${rvScore}/5`;
  let msg = 'Keep practicing — you\'ll get there!';
  if (rvScore === 5) msg = 'Perfect score! Amazing work! 🌟';
  else if (rvScore >= 4) msg = 'Great job! Almost perfect!';
  else if (rvScore >= 3) msg = 'Good work! Keep it up!';
  document.getElementById('rvResultMsg').textContent = msg;
  document.getElementById('rvResultCard').hidden = false;
  Confetti.burst(60 + rvScore*20);
}
document.getElementById('rvPlayAgain').addEventListener('click', ()=>{ AudioEngine.beep('click'); initMiniReview(); });

