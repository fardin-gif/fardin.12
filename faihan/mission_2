<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Fardin (DU Physics)</title>

<!-- Google Fonts: Hind Siliguri + Noto Sans Bengali for Bangla, Poppins + Nunito for English -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700;800&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;500;600;700&family=Noto+Sans+Bengali:wght@100..900&display=swap');
</style>

<style>
/* ==========================================================================
   0. DESIGN TOKENS — identical to Mission 1 so this feels like the same app
   ========================================================================== */
:root{
  --blue:        #5FBEE8;
  --blue-deep:   #2D9CD1;
  --blue-pale:   #E4F6FF;
  --green:       #64D4A0;
  --green-deep:  #2FB57F;
  --green-pale:  #E4FBF1;
  --orange:      #FFA552;
  --orange-deep: #F0822A;
  --orange-pale: #FFF1E1;
  --yellow:      #FFD23F;
  --yellow-deep: #F5B700;
  --yellow-pale: #FFF9E1;
  --white:       #FFFFFF;
  --ink:         #3C3854;
  --ink-soft:    #6D6A85;
  --bg:          #FBFCFF;
  --shadow-soft: 0 12px 30px rgba(60, 56, 84, 0.10);
  --shadow-pop:  0 18px 40px rgba(60, 56, 84, 0.16);
  --radius-lg:   32px;
  --radius-md:   24px;
  --radius-sm:   16px;
  --font-bn:     'Hind Siliguri', 'Noto Sans Bengali', sans-serif;   /* All Bangla text uses this font */
  --font-en:     'Poppins', 'Nunito', sans-serif;
  --font-body:   'Nunito', sans-serif;
}

*{ box-sizing: border-box; }
html{ scroll-behavior: smooth; }
body{
  margin:0;
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--ink);
  overflow-x: hidden;
  -webkit-tap-highlight-color: transparent;
}
img, svg{ display:block; max-width:100%; }
button{ font-family: inherit; cursor:pointer; border:none; background:none; }
button:focus-visible, [tabindex]:focus-visible, a:focus-visible{
  outline: 4px solid var(--blue-deep);
  outline-offset: 3px;
}
[lang="bn"]{ font-family: var(--font-bn); }

@media (prefers-reduced-motion: reduce){
  *{ animation-duration: 0.01ms !important; animation-iteration-count: 1 !important; transition-duration: 0.01ms !important; scroll-behavior:auto !important; }
}

/* ==========================================================================
   1. BACKGROUND DECOR
   ========================================================================== */
.bg-decor{ position: fixed; inset:0; z-index:-1; overflow:hidden; pointer-events:none; }
.bg-decor .blob{ position:absolute; border-radius:50%; opacity:0.35; animation: float 14s ease-in-out infinite; }
.bg-decor .blob:nth-child(1){ width:260px; height:260px; background:var(--blue-pale); top:-60px; left:-60px; }
.bg-decor .blob:nth-child(2){ width:220px; height:220px; background:var(--yellow-pale); top:20%; right:-80px; animation-delay:2s; }
.bg-decor .blob:nth-child(3){ width:300px; height:300px; background:var(--green-pale); bottom:5%; left:-100px; animation-delay:4s; }
.bg-decor .blob:nth-child(4){ width:200px; height:200px; background:var(--orange-pale); bottom:-60px; right:10%; animation-delay:1s; }
@keyframes float{ 0%,100%{ transform: translateY(0) translateX(0);} 50%{ transform: translateY(-24px) translateX(14px);} }

/* ==========================================================================
   2. MISSION NAV (fixed top) — 3 big pills: Basic / Practice / Home
      All three are free to enter — no completion gating between them.
   ========================================================================== */
.mission-nav{
  position: fixed; top:0; left:0; right:0; z-index:100;
  display:flex; align-items:center; justify-content:center; gap:10px; flex-wrap:wrap;
  padding: 14px 16px;
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(10px);
  box-shadow: 0 4px 18px rgba(60,56,84,0.06);
}
.mission-nav .brand{
  font-family: var(--font-en); font-weight:800; font-size:0.85rem; color:var(--ink);
  margin-right:10px; white-space:nowrap; display:flex; align-items:center; gap:6px;
}
.mission-pill{
  font-family: var(--font-en); font-weight:700; font-size:0.85rem;
  padding: 10px 20px; border-radius:100px; background:#EDEBF7; color:var(--ink-soft);
  display:flex; align-items:center; gap:6px; transition: all 0.25s ease;
}
.mission-pill.unlocked{ background: var(--white); box-shadow: var(--shadow-soft); color:var(--ink); cursor:pointer; }
.mission-pill.unlocked:hover{ transform: translateY(-2px); }
.mission-pill.active{
  background: linear-gradient(135deg, var(--orange), var(--orange-deep)); color:var(--white);
  box-shadow: 0 8px 20px rgba(240,130,42,0.35);
}

/* ==========================================================================
   3. LAYOUT — TOP-LEVEL SECTIONS (Welcome / Basic / Practice / Home)
   ========================================================================== */
.section{
  min-height:100vh;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  padding: 110px 20px 70px;
  position:relative;
  opacity:0; transform: translateY(40px);
  pointer-events:none;
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.section.locked{ display:none; }
.section.revealed{ opacity:1; transform:none; pointer-events:auto; }

.section-eyebrow{
  font-family: var(--font-en); font-weight:700; letter-spacing:0.08em;
  text-transform:uppercase; font-size:0.8rem; color: var(--blue-deep);
  background: var(--blue-pale); padding:8px 20px; border-radius:100px; margin-bottom:14px;
}
.section-eyebrow.orange{ color:var(--orange-deep); background:var(--orange-pale); }
.section-eyebrow.green{ color:var(--green-deep); background:var(--green-pale); }
.section-title{
  font-family: var(--font-en); font-weight:800; font-size: clamp(1.6rem, 4vw, 2.4rem);
  text-align:center; margin:0 0 8px;
}
.section-sub{
  font-family: var(--font-body); font-weight:600; color: var(--ink-soft);
  text-align:center; margin:0 0 30px; font-size:1.05rem; max-width:480px;
}

.card{
  background: var(--white); border-radius: var(--radius-lg); box-shadow: var(--shadow-soft);
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}

.btn{
  font-family: var(--font-en); font-weight:700; font-size:1.05rem;
  padding: 18px 40px; border-radius:100px; color:var(--white);
  background: linear-gradient(135deg, var(--blue), var(--blue-deep));
  box-shadow: 0 10px 24px rgba(45,156,209,0.35);
  display:inline-flex; align-items:center; gap:10px;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
  min-height:60px;
}
.btn:hover{ transform: translateY(-3px) scale(1.02); box-shadow: 0 14px 30px rgba(45,156,209,0.4); }
.btn:active{ transform: translateY(0) scale(0.98); }
.btn.green{ background: linear-gradient(135deg, var(--green), var(--green-deep)); box-shadow:0 10px 24px rgba(47,181,127,0.35); }
.btn.orange{ background: linear-gradient(135deg, var(--orange), var(--orange-deep)); box-shadow:0 10px 24px rgba(240,130,42,0.35); }
.btn.ghost{ background: var(--white); color: var(--ink); box-shadow: var(--shadow-soft); border: 2px solid #ECEAF6; }
.btn.ghost:hover{ transform: translateY(-2px); }
.btn:disabled{ opacity:0.4; pointer-events:none; }
.btn-row{ display:flex; gap:16px; flex-wrap:wrap; justify-content:center; margin-top:28px; }

.speaker-btn{
  width:64px; height:64px; border-radius:50%;
  background: linear-gradient(135deg, var(--yellow), var(--yellow-deep));
  box-shadow: 0 8px 20px rgba(245,183,0,0.4);
  display:flex; align-items:center; justify-content:center; font-size:1.6rem;
  transition: transform 0.15s ease;
}
.speaker-btn:hover{ transform: scale(1.08); }
.speaker-btn:active{ transform: scale(0.94); }
.speaker-btn.pulse{ animation: pulse-ring 1.4s ease-out; }
@keyframes pulse-ring{
  0%{ box-shadow:0 8px 20px rgba(245,183,0,0.4), 0 0 0 0 rgba(245,183,0,0.5); }
  100%{ box-shadow:0 8px 20px rgba(245,183,0,0.4), 0 0 0 18px rgba(245,183,0,0); }
}

/* ==========================================================================
   4. MASCOT — "Tubu the Cloud" (inline SVG, reused via template)
   ========================================================================== */
.mascot-wrap{ display:flex; flex-direction:column; align-items:center; margin-bottom:18px; }
.mascot{ width:150px; height:auto; animation: bob 3.2s ease-in-out infinite; }
@keyframes bob{ 0%,100%{ transform: translateY(0);} 50%{ transform: translateY(-10px);} }
.speech-bubble{
  background: var(--white); border-radius: 22px; padding:14px 26px;
  box-shadow: var(--shadow-soft); font-family:var(--font-en); font-weight:700;
  font-size:1.05rem; margin-top:10px; position:relative; text-align:center; max-width:360px;
}
.speech-bubble[lang="bn"]{ font-family: var(--font-bn); font-size:1.3rem; }
.speech-bubble::after{
  content:''; position:absolute; top:-10px; left:50%; transform:translateX(-50%);
  border-width:0 10px 12px 10px; border-style:solid;
  border-color: transparent transparent var(--white) transparent;
}

/* ==========================================================================
   5. WELCOME SCREEN
   ========================================================================== */
#welcome{ text-align:center; }
.welcome-badge{
  font-family:var(--font-en); font-weight:800; letter-spacing:0.1em; text-transform:uppercase;
  font-size:0.85rem; color:var(--orange-deep); background:var(--orange-pale);
  padding:10px 24px; border-radius:100px; margin-bottom:18px; display:inline-block;
}
.welcome-title{
  font-family: var(--font-en); font-weight:800; font-size:clamp(2.2rem,7vw,3.6rem);
  margin: 6px 0 4px; background: linear-gradient(135deg, var(--blue-deep), var(--green-deep));
  -webkit-background-clip:text; background-clip:text; color:transparent;
}
.welcome-sub{ font-size:1.2rem; color:var(--ink-soft); font-weight:700; margin-bottom:6px; }
.welcome-emoji-row{ font-size:2.4rem; margin: 18px 0 8px; letter-spacing:10px; }

/* ==========================================================================
   6. SUB-STEP NAV (used inside Basic and Practice sections)
   ========================================================================== */
.substep-nav{ display:flex; gap:10px; flex-wrap:wrap; justify-content:center; margin-bottom:34px; }
.substep-btn{
  font-family: var(--font-en); font-weight:700; font-size:0.82rem;
  padding: 12px 20px; border-radius:100px; background: var(--white);
  box-shadow: var(--shadow-soft); color: var(--ink-soft);
  display:flex; align-items:center; gap:8px; transition: all 0.2s ease; border:2px solid transparent;
}
.substep-btn .num{
  width:22px; height:22px; border-radius:50%; background:#EDEBF7;
  display:flex; align-items:center; justify-content:center; font-size:0.72rem; font-weight:800; color:var(--ink-soft);
}
.substep-btn.current{
  background: linear-gradient(135deg, var(--blue), var(--blue-deep)); color:var(--white);
  box-shadow: 0 8px 20px rgba(45,156,209,0.35);
}
.substep-btn.current .num{ background: rgba(255,255,255,0.3); color:var(--white); }
.substep-btn.done{ border-color: var(--green); color: var(--green-deep); }
.substep-btn.done .num{ background: var(--green); color:var(--white); }
.substep-btn.locked{ opacity:0.45; cursor:not-allowed; pointer-events:none; }
.substep-btn:not(.locked):not(.current):hover{ transform: translateY(-2px); }

.step-panel{ display:flex; flex-direction:column; align-items:center; width:100%; animation: panelIn 0.4s ease; }
.step-panel[hidden]{ display:none; }
@keyframes panelIn{ from{ opacity:0; transform:translateY(12px);} to{ opacity:1; transform:none;} }

/* ==========================================================================
   7. LEARNING PANEL — one word carousel
   ========================================================================== */
.word-card{ width:min(90vw, 380px); padding: 46px 32px 38px; text-align:center; display:flex; flex-direction:column; align-items:center; gap:6px; }
.word-illustration{ font-size:6.5rem; line-height:1; margin-bottom:10px; filter: drop-shadow(0 10px 14px rgba(60,56,84,0.15)); }
.word-bangla{ font-family: var(--font-bn); font-weight:700; font-size: clamp(3.4rem, 12vw, 4.6rem); color: var(--ink); margin:0; line-height:1; }
.word-english{ font-family: var(--font-en); font-weight:600; font-size:1rem; color: var(--ink-soft); text-transform:uppercase; letter-spacing:0.06em; margin: 6px 0 20px; }
.word-nav{ display:flex; align-items:center; gap:22px; margin-top:30px; }
.nav-arrow{ width:54px; height:54px; border-radius:50%; background:var(--white); box-shadow: var(--shadow-soft); font-size:1.4rem; display:flex; align-items:center; justify-content:center; color: var(--blue-deep); transition: transform 0.15s ease; }
.nav-arrow:hover{ transform: scale(1.08); }
.nav-arrow:disabled{ opacity:0.3; pointer-events:none; }
.progress-dots{ display:flex; gap:8px; }
.progress-dots .pd{ width:9px; height:9px; border-radius:50%; background:#E4E2F0; transition: all 0.3s ease; }
.progress-dots .pd.active{ background: var(--blue-deep); width:22px; border-radius:6px; }

/* ==========================================================================
   8. PRONUNCIATION PANEL
   ========================================================================== */
.practice-mode-toggle{ display:flex; gap:10px; background:var(--white); padding:6px; border-radius:100px; box-shadow: var(--shadow-soft); margin-bottom: 30px; }
.practice-mode-toggle button{ font-family:var(--font-en); font-weight:700; padding:10px 22px; border-radius:100px; color:var(--ink-soft); font-size:0.9rem; transition: all 0.2s ease; }
.practice-mode-toggle button.active{ background: linear-gradient(135deg, var(--blue), var(--blue-deep)); color:var(--white); }
.practice-stage{ width:min(90vw, 380px); text-align:center; padding: 46px 32px; display:flex; flex-direction:column; align-items:center; }
.repeat-hint{ font-family:var(--font-en); font-weight:700; font-size:0.9rem; color: var(--green-deep); background: var(--green-pale); padding:8px 18px; border-radius:100px; margin-top:18px; }

/* ==========================================================================
   9. READING PANEL — flashcard grid (with a speaker button on every card)
   ========================================================================== */
.flash-grid{ display:grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap:20px; width:min(92vw, 780px); margin-top:10px; }
.flash-card{ position:relative; aspect-ratio: 3/4; border-radius: var(--radius-md); background:var(--white); box-shadow: var(--shadow-soft); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:10px; padding:16px; transition: transform 0.35s cubic-bezier(.34,1.56,.64,1), box-shadow 0.3s ease; }
.flash-card:hover{ transform: translateY(-6px) rotate(-1deg); box-shadow: var(--shadow-pop); }
.flash-card .fc-emoji{ font-size:3rem; }
.flash-card .fc-bn{ font-family:var(--font-bn); font-weight:700; font-size:1.8rem; }
.fc-speak{
  position:absolute; top:10px; right:10px; width:32px; height:32px; border-radius:50%;
  background: var(--yellow-pale); display:flex; align-items:center; justify-content:center;
  font-size:0.95rem; box-shadow: 0 4px 10px rgba(245,183,0,0.3); transition: transform 0.15s ease;
}
.fc-speak:hover{ transform: scale(1.12); }
.flash-card.enlarged{ position:fixed; inset:0; margin:auto; width:min(85vw,360px); height:min(70vh,420px); z-index:200; transform:none; box-shadow: 0 30px 60px rgba(0,0,0,0.3); }
.flash-card.enlarged .fc-emoji{ font-size:6rem; }
.flash-card.enlarged .fc-bn{ font-size:3.6rem; }
.flash-card.enlarged .fc-speak{ width:44px; height:44px; font-size:1.2rem; }
.overlay-dim{ position:fixed; inset:0; background:rgba(60,56,84,0.35); z-index:190; opacity:0; pointer-events:none; transition:opacity 0.3s ease; }
.overlay-dim.show{ opacity:1; pointer-events:auto; }

/* ==========================================================================
   10. GAMES — shared chrome
   ========================================================================== */
.game-panel{ width:min(94vw, 720px); display:flex; flex-direction:column; align-items:center; }
.game-hud{ display:flex; align-items:center; gap:16px; margin-bottom:26px; flex-wrap:wrap; justify-content:center; }
.hud-chip{ font-family:var(--font-en); font-weight:700; font-size:0.9rem; background:var(--white); padding:10px 18px; border-radius:100px; box-shadow: var(--shadow-soft); display:flex; align-items:center; gap:6px; }
.stars-row{ display:flex; gap:6px; font-size:1.3rem; }
.stars-row .star{ opacity:0.25; transition: all 0.3s ease; }
.stars-row .star.earned{ opacity:1; transform: scale(1.15); }
.game-prompt{ text-align:center; margin-bottom:26px; display:flex; flex-direction:column; align-items:center; gap:14px; }

/* Generic multiple-choice cards — reused by Picture Match, Who's This?,
   Listen & Click, and the Mini Review Challenge, so every activity looks
   and behaves the same way. */
.choice-grid{ display:grid; grid-template-columns: repeat(2, 1fr); gap:18px; width:min(90vw, 460px); }
.choice-grid.five{ grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); width:min(94vw, 640px); }
.choice-card{
  border-radius: var(--radius-md); background:var(--white); box-shadow: var(--shadow-soft);
  display:flex; align-items:center; justify-content:center; padding:18px 12px; min-height:100px;
  text-align:center; border:4px solid transparent;
  transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.2s ease;
}
.choice-card:hover{ transform: translateY(-4px) scale(1.03); }
.choice-card.emoji{ aspect-ratio:1; font-size:3.4rem; }
.choice-card.word{ font-family:var(--font-bn); font-weight:700; font-size:1.7rem; }
.choice-card.meaning{ font-family:var(--font-en); font-weight:700; font-size:1rem; }
.choice-card.flash-good{ border-color: var(--green); background: var(--green-pale); animation: correct-pop 0.5s ease; }
.choice-card.flash-bad{ border-color: var(--orange); background: var(--orange-pale); animation: shake 0.5s ease; }
@keyframes correct-pop{ 0%{transform:scale(1);} 50%{transform:scale(1.12);} 100%{transform:scale(1);} }
@keyframes shake{ 0%,100%{transform:translateX(0);} 25%{transform:translateX(-8px);} 75%{transform:translateX(8px);} }
.feedback-msg{ font-family:var(--font-en); font-weight:800; font-size:1.2rem; margin-top:22px; min-height:34px; text-align:center; }
.feedback-msg.good{ color: var(--green-deep); }
.feedback-msg.retry{ color: var(--orange-deep); }

/* ==========================================================================
   11. WRITING PRACTICE PANEL (Teacher Mode)
   ========================================================================== */
.dictation-card{ width:min(90vw, 420px); padding:44px 34px; text-align:center; }
.write-box{ margin-top:26px; border-radius: var(--radius-sm); border:3px dashed #D7D4EA; background: repeating-linear-gradient( to bottom, transparent 0, transparent 38px, #EFEDF7 39px, #EFEDF7 40px ); height:130px; display:flex; align-items:center; justify-content:center; color: var(--ink-soft); font-family:var(--font-en); font-weight:600; font-size:0.9rem; text-align:center; padding:10px; }
.teacher-tag{ font-family:var(--font-en); font-weight:700; font-size:0.75rem; letter-spacing:0.06em; text-transform:uppercase; color:var(--orange-deep); background:var(--orange-pale); padding:6px 16px; border-radius:100px; margin-bottom:18px; display:inline-block; }

/* ==========================================================================
   12. MINI REVIEW CHALLENGE
   ========================================================================== */
.review-prompt-emoji{ font-size:6rem; margin-bottom:4px; filter: drop-shadow(0 10px 14px rgba(60,56,84,0.15)); }
.review-prompt-word{ font-family:var(--font-bn); font-weight:700; font-size: clamp(3rem, 10vw, 4rem); margin-bottom:4px; }
.review-prompt-label{ font-family:var(--font-en); font-weight:700; color:var(--ink-soft); }
.review-score-card{ text-align:center; padding:44px 36px; width:min(90vw,380px); }
.review-score-big{ font-family:var(--font-en); font-weight:800; font-size:3rem; color:var(--blue-deep); margin:8px 0; }

/* ==========================================================================
   13. HOME SECTION — homework + reward
   ========================================================================== */
.homework-card{ width:min(92vw, 560px); padding: 40px 34px; }
.hw-item{ display:flex; align-items:flex-start; gap:16px; padding:16px 0; border-bottom:2px solid #F3F1FA; }
.hw-item:last-child{ border-bottom:none; }
.hw-num{ width:38px; height:38px; min-width:38px; border-radius:50%; background: var(--yellow-pale); color:var(--yellow-deep); font-weight:800; font-family:var(--font-en); display:flex; align-items:center; justify-content:center; font-size:1.1rem; }
.hw-text{ font-weight:700; font-size:1.02rem; padding-top:6px; }
.hw-text .bn-inline{ font-family:var(--font-bn); font-size:1.3rem; color:var(--blue-deep); }
.hw-emoji{ font-size:1.6rem; margin-left:auto; padding-top:2px; }

.reward-block{ text-align:center; margin-top:40px; }
.trophy{ font-size:5.5rem; animation: trophy-in 0.8s cubic-bezier(.34,1.56,.64,1); }
@keyframes trophy-in{ 0%{ transform: scale(0) rotate(-20deg); opacity:0;} 100%{ transform:scale(1) rotate(0); opacity:1;} }
.reward-stars{ font-size:2.4rem; margin: 12px 0 4px; display:flex; gap:10px; justify-content:center; }
.reward-stars span{ opacity:0; transform: scale(0.2); transition: all 0.4s cubic-bezier(.34,1.56,.64,1); }
.reward-stars span.show{ opacity:1; transform: scale(1); }
.badge{ width:110px; height:110px; margin: 20px auto 8px; }
.reward-title{ font-family:var(--font-bn); font-weight:700; font-size:2.2rem; margin: 6px 0 2px; }
.reward-sub{ font-weight:700; color:var(--ink-soft); margin-bottom: 6px; }
.reward-sub[lang="bn"]{ font-family:var(--font-bn); font-size:1.2rem; }
.reward-mission-tag{
  font-family:var(--font-en); font-weight:800; font-size:0.85rem; color:var(--green-deep);
  background:var(--green-pale); padding:8px 20px; border-radius:100px; display:inline-block; margin-top:8px;
}

/* ==========================================================================
   14. CONFETTI CANVAS
   ========================================================================== */
#confetti-canvas{ position:fixed; inset:0; pointer-events:none; z-index:300; }

/* ==========================================================================
   15. RESPONSIVE TWEAKS
   ========================================================================== */
@media (max-width:480px){
  .section{ padding:150px 14px 60px; }
  .word-illustration{ font-size:5.2rem; }
  .choice-grid{ gap:12px; }
