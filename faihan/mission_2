<script>
/* ==========================================================================
   DATA — single source of truth. Swapping this array (and welcome/homework
   copy) is all a future mission needs.
   ========================================================================== */
const WORDS = [
  { id:'dadi', bn:'দাদি', en:"Grandmother (Paternal)", emoji:'👵' },
  { id:'nani', bn:'নানি', en:"Grandmother (Maternal)", emoji:'🧓' },
  { id:'chacha', bn:'চাচা', en:"Uncle (Father's Brother)", emoji:'👨' },
  { id:'khala', bn:'খালা', en:"Aunt (Mother's Sister)", emoji:'👩‍🦳' },
  { id:'fufu', bn:'ফুফু', en:"Aunt (Father's Sister)", emoji:'👩‍🦱' },
];

/* ==========================================================================
   AUDIO ENGINE
   ========================================================================== */
const AudioEngine = (() => {
  let bnVoice = null;
  function pickVoice(){
    const voices = window.speechSynthesis ? speechSynthesis.getVoices() : [];
    bnVoice = voices.find(v => /bn/i.test(v.lang)) || null;
  }
  if ('speechSynthesis' in window){ pickVoice(); speechSynthesis.onvoiceschanged = pickVoice; }

  function speak(text){
    if (!('speechSynthesis' in window)){ beep('click'); return; }
    speechSynthesis.cancel();
    const utter = new SpeechSynthesisUtterance(text);
    utter.lang = bnVoice ? bnVoice.lang : 'bn-BD';
    if (bnVoice) utter.voice = bnVoice;
    utter.rate = 0.85; utter.pitch = 1.05;
    speechSynthesis.speak(utter);
  }

  let ctx = null;
  function getCtx(){ if (!ctx) ctx = new (window.AudioContext || window.webkitAudioContext)(); return ctx; }
  function tone(freq, start, duration, type='sine', gainPeak=0.14){
    const c = getCtx();
    const osc = c.createOscillator(); const gain = c.createGain();
    osc.type = type; osc.frequency.value = freq;
    gain.gain.setValueAtTime(0, c.currentTime + start);
    gain.gain.linearRampToValueAtTime(gainPeak, c.currentTime + start + 0.03);
    gain.gain.exponentialRampToValueAtTime(0.001, c.currentTime + start + duration);
    osc.connect(gain).connect(c.destination);
    osc.start(c.currentTime + start); osc.stop(c.currentTime + start + duration + 0.05);
  }
  function beep(kind){
    try{
      if (kind === 'correct'){ tone(523,0,0.16); tone(659,0.12,0.18); tone(784,0.24,0.24); }
      else if (kind === 'wrong'){ tone(330,0,0.18,'sine',0.1); tone(280,0.14,0.22,'sine',0.09); }
      else if (kind === 'click'){ tone(600,0,0.08,'sine',0.08); }
      else if (kind === 'reward'){ [523,659,784,1046].forEach((f,i)=>tone(f, i*0.12, 0.22)); }
    }catch(e){ /* Web Audio unsupported — visuals still work */ }
  }
  return { speak, beep };
})();

/* ==========================================================================
   CONFETTI
   ========================================================================== */
const Confetti = (() => {
  const canvas = document.getElementById('confetti-canvas');
  const ctx = canvas.getContext('2d');
  let particles = []; let running = false;
  const colors = ['#5FBEE8','#64D4A0','#FFA552','#FFD23F','#FF6B8A'];
  function resize(){ canvas.width = innerWidth; canvas.height = innerHeight; }
  window.addEventListener('resize', resize); resize();
  function burst(count = 80){
    for (let i=0;i<count;i++){
      particles.push({ x: canvas.width/2 + (Math.random()-0.5)*200, y: canvas.height*0.35,
        vx: (Math.random()-0.5)*10, vy: Math.random()*-8 - 4, size: Math.random()*8+5,
        color: colors[Math.floor(Math.random()*colors.length)], rot: Math.random()*360, vr: (Math.random()-0.5)*10, life:0 });
    }
    if (!running){ running = true; requestAnimationFrame(loop); }
  }
  function loop(){
    ctx.clearRect(0,0,canvas.width,canvas.height);
    particles.forEach(p=>{
      p.vy += 0.28; p.x += p.vx; p.y += p.vy; p.rot += p.vr; p.life++;
      ctx.save(); ctx.translate(p.x,p.y); ctx.rotate(p.rot*Math.PI/180);
      ctx.fillStyle = p.color; ctx.fillRect(-p.size/2,-p.size/2,p.size,p.size*0.6);
      ctx.restore();
    });
    particles = particles.filter(p => p.y < canvas.height + 40 && p.life < 260);
    if (particles.length){ requestAnimationFrame(loop); } else { running = false; }
  }
  return { burst };
})();

function shuffleArray(arr){
  const a = [...arr];
  for (let i=a.length-1;i>0;i--){ const j = Math.floor(Math.random()*(i+1)); [a[i],a[j]]=[a[j],a[i]]; }
  return a;
}
// Returns `count` random words other than `target` — used to build wrong answers.
function buildDistractors(target, count=3){
  return shuffleArray(WORDS.filter(w=>w.id!==target.id)).slice(0,count);
}
function injectMascot(containerId){
  const tpl = document.getElementById('mascotTemplate');
  document.getElementById(containerId).appendChild(tpl.content.cloneNode(true));
}
injectMascot('mascotWelcome');

/* ==========================================================================
   TOP-LEVEL SECTION + MISSION PILL CONTROL
   ========================================================================== */
const pills = { basic: document.getElementById('pillBasic'), practice: document.getElementById('pillPractice'), home: document.getElementById('pillHome') };

function revealSection(id){
  const el = document.getElementById(id);
  el.classList.remove('locked');
  void el.offsetWidth;
  el.classList.add('revealed');
}
function unlockTopSection(id){
  revealSection(id);
  setActivePill(id);
  setTimeout(()=>{ document.getElementById(id).scrollIntoView({ behavior:'smooth', block:'start' }); }, 60);
}
function setActivePill(id){
  Object.entries(pills).forEach(([key,p])=> p.classList.toggle('active', key===id));
}
Object.entries(pills).forEach(([key, p])=>{
  p.addEventListener('click', ()=>{
    AudioEngine.beep('click');
    document.getElementById(key).scrollIntoView({ behavior:'smooth', block:'start' });
    setActivePill(key);
  });
});

// Track which top-level section is in view to keep the active pill accurate.
const topObserver = new IntersectionObserver((entries)=>{
  entries.forEach(entry=>{
    if (entry.isIntersecting && pills[entry.target.id]){ setActivePill(entry.target.id); }
  });
}, { threshold:0.5 });
['basic','practice','home'].forEach(id=> topObserver.observe(document.getElementById(id)));

/* ==========================================================================
   WELCOME → all three sections open together (free to enter)
   ========================================================================== */
document.getElementById('startBtn').addEventListener('click', ()=>{
  AudioEngine.beep('click');
  unlockTopSection('basic');
