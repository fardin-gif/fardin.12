  revealSection('home');
  initLearning();
  initPictureMatch();
});

/* ==========================================================================
   BASIC SUB-STEP ENGINE (sequential gating — unchanged from Mission 1)
   ========================================================================== */
const basicOrder = ['learning','pronunciation','reading'];
function switchBasicPanel(step){
  basicOrder.forEach(s=>{ document.getElementById('panel-'+s).hidden = (s !== step); });
  document.querySelectorAll('#basicSubNav .substep-btn').forEach(btn=>{
    btn.classList.toggle('current', btn.dataset.step === step);
  });
}
function markBasicStepDone(step, nextStep){
  const btn = document.querySelector(`#basicSubNav .substep-btn[data-step="${step}"]`);
  btn.classList.remove('current'); btn.classList.add('done');
  if (nextStep){
    const nextBtn = document.querySelector(`#basicSubNav .substep-btn[data-step="${nextStep}"]`);
    nextBtn.classList.remove('locked'); nextBtn.disabled = false;
    switchBasicPanel(nextStep);
  }
}
document.querySelectorAll('#basicSubNav .substep-btn').forEach(btn=>{
  btn.addEventListener('click', ()=>{
    if (btn.classList.contains('locked')) return;
    AudioEngine.beep('click');
    switchBasicPanel(btn.dataset.step);
  });
});

/* --- Basic Step 1: Learning --- */
let learnIdx = 0;
function initLearning(){
  document.getElementById('learnDots').innerHTML = WORDS.map((_,i)=>`<div class="pd${i===0?' active':''}"></div>`).join('');
  renderLearnWord();
}
function renderLearnWord(){
  const w = WORDS[learnIdx];
  document.getElementById('learnEmoji').textContent = w.emoji;
  document.getElementById('learnBangla').textContent = w.bn;
  document.getElementById('learnEnglish').textContent = w.en;
  document.querySelectorAll('#learnDots .pd').forEach((d,i)=>d.classList.toggle('active', i===learnIdx));
  document.getElementById('learnPrev').disabled = learnIdx === 0;
  document.getElementById('learnDoneRow').style.display = learnIdx === WORDS.length-1 ? 'flex' : 'none';
}
document.getElementById('learnSpeaker').addEventListener('click', (e)=>{
  AudioEngine.speak(WORDS[learnIdx].bn);
  e.currentTarget.classList.remove('pulse'); void e.currentTarget.offsetWidth; e.currentTarget.classList.add('pulse');
});
document.getElementById('learnPrev').addEventListener('click', ()=>{ if(learnIdx>0){ learnIdx--; renderLearnWord(); AudioEngine.beep('click'); }});
document.getElementById('learnNext').addEventListener('click', ()=>{
  AudioEngine.beep('click');
  if (learnIdx < WORDS.length-1){ learnIdx++; renderLearnWord(); }
});
document.getElementById('learnContinue').addEventListener('click', ()=>{
  AudioEngine.beep('click');
  markBasicStepDone('learning','pronunciation');
  initPronunciation();
});

/* --- Basic Step 2: Pronunciation --- */
let pracIdx = 0;
let pracMode = 'order';
let pracOrderShuffled = [...WORDS];
function initPronunciation(){ pracIdx = 0; renderPracWord(); }
function currentPracList(){ return pracMode === 'random' ? pracOrderShuffled : WORDS; }
function renderPracWord(){
  const list = currentPracList();
  const w = list[pracIdx % list.length];
  document.getElementById('pracEmoji').textContent = w.emoji;
  document.getElementById('pracBangla').textContent = w.bn;
  document.getElementById('pracEnglish').textContent = w.en;
}
document.getElementById('modeOrder').addEventListener('click', ()=>{
  pracMode = 'order'; pracIdx = 0;
  document.getElementById('modeOrder').classList.add('active');
  document.getElementById('modeRandom').classList.remove('active');
  renderPracWord(); AudioEngine.beep('click');
});
document.getElementById('modeRandom').addEventListener('click', ()=>{
  pracMode = 'random'; pracOrderShuffled = shuffleArray(WORDS); pracIdx = 0;
  document.getElementById('modeRandom').classList.add('active');
  document.getElementById('modeOrder').classList.remove('active');
  renderPracWord(); AudioEngine.beep('click');
});
document.getElementById('pracSpeaker').addEventListener('click', (e)=>{
  const list = currentPracList();
  AudioEngine.speak(list[pracIdx % list.length].bn);
  e.currentTarget.classList.remove('pulse'); void e.currentTarget.offsetWidth; e.currentTarget.classList.add('pulse');
});
document.getElementById('pracAnother').addEventListener('click', ()=>{
  AudioEngine.beep('click');
  pracIdx++;
  if (pracMode === 'random' && pracIdx % WORDS.length === 0){ pracOrderShuffled = shuffleArray(WORDS); }
  renderPracWord();
});
document.getElementById('pracContinue').addEventListener('click', ()=>{
  AudioEngine.beep('click');
  markBasicStepDone('pronunciation','reading');
  initReading();
});

/* --- Basic Step 3: Reading --- */
let readingOrder = [...WORDS];
function initReading(){ readingOrder = [...WORDS]; renderFlashGrid(); }
function renderFlashGrid(){
  const grid = document.getElementById('flashGrid');
  grid.innerHTML = '';
  readingOrder.forEach(w=>{
    const card = document.createElement('div');
    card.className = 'flash-card'; card.tabIndex = 0;
    card.setAttribute('role','button'); card.setAttribute('aria-label', `${w.en} flashcard`);
    card.innerHTML = `<div class="fc-emoji">${w.emoji}</div><div class="fc-bn" lang="bn">${w.bn}</div><button class="fc-speak" aria-label="Play ${w.en}">🔊</button>`;
    card.addEventListener('click', ()=> toggleEnlarge(card, w));
    card.addEventListener('keydown', (e)=>{ if(e.key==='Enter'||e.key===' '){ e.preventDefault(); toggleEnlarge(card,w); }});
    card.querySelector('.fc-speak').addEventListener('click', (e)=>{ e.stopPropagation(); AudioEngine.speak(w.bn); });
    grid.appendChild(card);
  });
}
function toggleEnlarge(card, w){
  const isEnlarged = card.classList.contains('enlarged');
  document.querySelectorAll('.flash-card.enlarged').forEach(c=>c.classList.remove('enlarged'));
  document.getElementById('overlayDim').classList.remove('show');
  if (!isEnlarged){
    card.classList.add('enlarged');
    document.getElementById('overlayDim').classList.add('show');
    AudioEngine.speak(w.bn);
  }
}
document.getElementById('overlayDim').addEventListener('click', ()=>{
  document.querySelectorAll('.flash-card.enlarged').forEach(c=>c.classList.remove('enlarged'));
  document.getElementById('overlayDim').classList.remove('show');
});
document.getElementById('shuffleBtn').addEventListener('click', ()=>{
  AudioEngine.beep('click'); readingOrder = shuffleArray(readingOrder); renderFlashGrid();
});
document.getElementById('readingContinue').addEventListener('click', ()=>{
  AudioEngine.beep('click');
  document.querySelector('#basicSubNav .substep-btn[data-step="reading"]').classList.remove('current');
  document.querySelector('#basicSubNav .substep-btn[data-step="reading"]').classList.add('done');
  document.getElementById('readingContinue').textContent = '🎉 Basics Complete!';
  document.getElementById('readingContinue').disabled = true;
});

/* ==========================================================================
   PRACTICE SUB-STEP ENGINE (free navigation, no gating, lazy-init)
   ========================================================================== */
let wiInitialized=false, lcInitialized=false, writingInitialized=false, reviewInitialized=false;
const practiceStepOrder = ['picture','whois','listen','writing','review'];
function switchPracticePanel(step){
  practiceStepOrder.forEach(s=>{ document.getElementById('panel-'+s).hidden = (s !== step); });
  document.querySelectorAll('#practiceSubNav .substep-btn').forEach(btn=>{
    btn.classList.toggle('current', btn.dataset.step === step);
  });
  if (step === 'whois' && !wiInitialized){ wiInitialized = true; initWhoIsThis(); }
  if (step === 'listen' && !lcInitialized){ lcInitialized = true; initListenClick(); }
  if (step === 'writing' && !writingInitialized){ writingInitialized = true; initWriting(); }
  if (step === 'review' && !reviewInitialized){ reviewInitialized = true; initMiniReview(); }
}
document.querySelectorAll('#practiceSubNav .substep-btn').forEach(btn=>{
  btn.addEventListener('click', ()=>{ AudioEngine.beep('click'); switchPracticePanel(btn.dataset.step); });
});
document.getElementById('pmGoNext').addEventListener('click', ()=>{ AudioEngine.beep('click'); switchPracticePanel('whois'); });
document.getElementById('wiGoNext').addEventListener('click', ()=>{ AudioEngine.beep('click'); switchPracticePanel('listen'); });
document.getElementById('lcGoNext').addEventListener('click', ()=>{ AudioEngine.beep('click'); switchPracticePanel('writing'); });

/* --- Practice: Picture Match ---
   Show a Bangla word; child picks the matching illustration from four. */
let pmOrder=[], pmRound=0, pmTarget=null, pmLocked=false;
function initPictureMatch(){
  pmOrder = shuffleArray(WORDS); pmRound = 0;
  document.querySelectorAll('#pmStars .star').forEach(s=>s.classList.remove('earned'));
  document.getElementById('pmDoneRow').style.display = 'none';
  loadPmRound();
}
function loadPmRound(){
  pmLocked = false;
  pmTarget = pmOrder[pmRound];
  document.getElementById('pmRound').textContent = pmRound+1;
  document.getElementById('pmTargetWord').textContent = pmTarget.bn;
  document.getElementById('pmFeedback').textContent = '';
  document.getElementById('pmFeedback').className = 'feedback-msg';

  const options = shuffleArray([pmTarget, ...buildDistractors(pmTarget)]);
  const grid = document.getElementById('pmOptions');
  grid.innerHTML = '';
  options.forEach(opt=>{
    const card = document.createElement('button');
    card.className = 'choice-card emoji'; card.setAttribute('aria-label', opt.en); card.textContent = opt.emoji;
    card.addEventListener('click', ()=> handlePmAnswer(card, opt));
    grid.appendChild(card);
  });
  setTimeout(()=> AudioEngine.speak(pmTarget.bn), 300);
}
document.getElementById('pmSpeaker').addEventListener('click', ()=> AudioEngine.speak(pmTarget.bn));
function handlePmAnswer(card, opt){
  if (pmLocked) return;
  const fb = document.getElementById('pmFeedback');
  if (opt.id === pmTarget.id){
    pmLocked = true;
    card.classList.add('flash-good');
    fb.textContent = '🎉 Correct! Great job!'; fb.className = 'feedback-msg good';
    AudioEngine.beep('correct'); Confetti.burst(60);
    document.querySelectorAll('#pmStars .star')[pmRound].classList.add('earned');
    setTimeout(()=>{
      pmRound++;
      if (pmRound < WORDS.length){ loadPmRound(); }
      else{
        document.getElementById('pmFeedback').textContent = '🏆 All pictures matched!';
        document.getElementById('pmDoneRow').style.display = 'flex';
      }
    }, 1100);
  } else {
    card.classList.add('flash-bad');
    fb.textContent = 'Try again — listen once more! 💛'; fb.className = 'feedback-msg retry';
    AudioEngine.beep('wrong');
    setTimeout(()=> card.classList.remove('flash-bad'), 500);
  }
}
document.getElementById('pmPlayAgain').addEventListener('click', ()=>{ AudioEngine.beep('click'); initPictureMatch(); });

